#!/usr/bin/env bash
set -euo pipefail

file_path="${1:-}"

if [[ -z "${file_path}" ]]; then
    exit 0
fi

# 使えるツールを優先順で試し、失敗したら次にフォールバックする
if command -v bat >/dev/null 2>&1; then
    if bat --color=always --style=plain --paging=never -- "${file_path}" 2>/dev/null; then
        exit 0
    fi
fi

if command -v batcat >/dev/null 2>&1; then
    if batcat --color=always --style=plain --paging=never -- "${file_path}" 2>/dev/null; then
        exit 0
    fi
fi

if command -v source-highlight >/dev/null 2>&1; then
    if source-highlight --failsafe -f esc -i "${file_path}" 2>/dev/null; then
        exit 0
    fi
fi

if command -v lesspipe >/dev/null 2>&1; then
    if lesspipe "${file_path}" 2>/dev/null; then
        exit 0
    fi
fi

cat -- "${file_path}"
