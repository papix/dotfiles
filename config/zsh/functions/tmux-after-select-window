#!/usr/bin/env zsh
set -euo pipefail

last_active_pane="${1:-}"
session_target="${2:-}"
client_target="${3:-}"
config_home="${XDG_CONFIG_HOME:-${HOME}/.config}"

if [[ -n "$last_active_pane" ]]; then
    tmux select-pane -t "$last_active_pane" >/dev/null 2>&1 || true
fi

if [[ -x "${config_home}/zsh/functions/tmux-status-line-refresh" ]]; then
    "${config_home}/zsh/functions/tmux-status-line-refresh" "$session_target" "$client_target"
    exit 0
fi

exit 0
