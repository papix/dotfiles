#!/usr/bin/env bash
set -euo pipefail

# pre-push フック
# gitleaks で push 対象コミットをスキャンする

ZERO_SHA="0000000000000000000000000000000000000000"

scan_gitleaks() {
    local log_opts="$1"
    local target="$2"

    echo "[gitleaks] Scanning for secrets in ${target}..."
    if ! gitleaks detect --log-opts="$log_opts" --verbose --redact; then
        echo ""
        echo "[ERROR] gitleaks detected potential secrets in pushed commits."
        echo "Please review and remove any sensitive information."
        echo ""
        echo "To skip this check temporarily:"
        echo "  SKIP=gitleaks git push"
        return 1
    fi
    echo "[gitleaks] No secrets detected in ${target}."
}

# SKIP 環境変数で gitleaks をスキップ可能
if [[ "${SKIP:-}" == *"gitleaks"* ]]; then
    echo "[gitleaks] Skipped by SKIP environment variable"
    exit 0
fi

# gitleaks が利用可能か確認
if ! command -v gitleaks >/dev/null 2>&1; then
    echo "[ERROR] gitleaks not found."
    echo "Install with: brew install gitleaks"
    echo ""
    echo "To skip this check: SKIP=gitleaks git push"
    exit 1
fi

scanned=0
while read -r local_ref local_sha remote_ref remote_sha; do
    if [[ -z "${local_ref:-}" || -z "${local_sha:-}" || -z "${remote_ref:-}" || -z "${remote_sha:-}" ]]; then
        continue
    fi

    # 削除 push は新規コミットを含まないためスキップ
    if [[ "$local_sha" == "$ZERO_SHA" ]]; then
        continue
    fi

    scanned=1

    if [[ "$remote_sha" == "$ZERO_SHA" ]]; then
        # 新規ブランチ push は既存参照に含まれないコミットのみ対象
        scan_gitleaks "${local_sha} --not --all" "$local_ref" || exit 1
    else
        scan_gitleaks "${remote_sha}..${local_sha}" "$local_ref" || exit 1
    fi
done

if [[ "$scanned" -eq 0 ]]; then
    echo "[gitleaks] No refs to scan. Skipping."
fi

exit 0
