#!/usr/bin/env bash
set -euo pipefail

# pre-commit フック
# prek 設定があるリポジトリでは設定ファイルへ処理を委譲する

HOOK_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT_DIR="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"

if [[ ! -f "$ROOT_DIR/.pre-commit-config.yaml" && ! -f "$ROOT_DIR/prek.toml" ]]; then
    exit 0
fi

hook_args=(hook-impl --hook-dir "$HOOK_DIR" --hook-type=pre-commit --skip-on-missing-config -- "$@")

run_prek() {
    local -a cmd=("$@")

    if "${cmd[@]}" --version >/dev/null 2>&1; then
        exec "${cmd[@]}" "${hook_args[@]}"
    fi
}

if [[ -n "${PREK:-}" ]]; then
    run_prek "$PREK"
fi

if command -v prek >/dev/null 2>&1; then
    run_prek prek
fi

if command -v mise >/dev/null 2>&1; then
    run_prek mise exec prek -- prek
fi

echo "[ERROR] prek not found."
echo "Install with: brew install prek"
echo "Or enable via mise: mise use -g prek@latest"
exit 1
