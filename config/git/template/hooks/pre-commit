#!/usr/bin/env bash
set -euo pipefail

# pre-commit フック
# lint-shell と gitleaks を実行する

ROOT_DIR="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"

# SKIP 環境変数で lint-shell/shellcheck をスキップ可能
if [[ "${SKIP:-}" == *"lint-shell"* || "${SKIP:-}" == *"shellcheck"* ]]; then
    echo "[lint-shell] Skipped by SKIP environment variable"
elif [[ -x "$ROOT_DIR/bin/lint-shell" ]]; then
    echo "[lint-shell] Running shellcheck suite..."
    if ! "$ROOT_DIR/bin/lint-shell"; then
        echo ""
        echo "[ERROR] lint-shell check failed."
        echo "Fix shellcheck findings and retry."
        echo ""
        echo "To skip this check temporarily:"
        echo "  SKIP=lint-shell git commit -m 'message'"
        exit 1
    fi
    echo "[lint-shell] Shellcheck suite passed."
else
    echo "[lint-shell] Not found in this repository. Skipping."
fi

# SKIP 環境変数で gitleaks をスキップ可能
if [[ "${SKIP:-}" == *"gitleaks"* ]]; then
    echo "[gitleaks] Skipped by SKIP environment variable"
    exit 0
fi

# gitleaks が利用可能か確認
if ! command -v gitleaks >/dev/null 2>&1; then
    echo "[ERROR] gitleaks not found."
    echo "Install with: brew install gitleaks"
    echo ""
    echo "To skip this check: SKIP=gitleaks git commit -m 'message'"
    exit 1
fi

# gitleaks でステージングされた変更をスキャン
echo "[gitleaks] Scanning for secrets..."
if ! gitleaks protect --staged --verbose --redact; then
    echo ""
    echo "[ERROR] gitleaks detected potential secrets in your commit."
    echo "Please review and remove any sensitive information."
    echo ""
    echo "To skip this check temporarily:"
    echo "  SKIP=gitleaks git commit -m 'message'"
    exit 1
fi

echo "[gitleaks] No secrets detected."
exit 0
