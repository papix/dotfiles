snippet u
	use strict;
	use warnings;
	use utf8;

	${0}

snippet env
	#!/usr/bin/env perl
	use strict;
	use warnings;
	use utf8;

	${0}

snippet pkg
	package `expand('%:p:s?.*lib/??:r:gs?/?::?')`;
	use strict;
	use warnings;
	use utf8;

	${0}

	1;

snippet dw
	use DDP { deparse => 1, use_prototypes => 0 };
	DDP::p ${0}

snippet slurp
	open my $fh, '<', ${0} or die "failed to open file: $!";
	my $content = do { local $/; <$fh> };
