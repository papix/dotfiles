########################################
# PATH
########################################
export GOPATH="${HOME}/.ghq"
export GOBIN="${GOPATH}/bin"

########################################
# Tools
########################################

# config
export XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-${HOME}/.config}"
export XDG_DATA_HOME="${XDG_DATA_HOME:-${HOME}/.local/share}"
export XDG_CACHE_HOME="${XDG_CACHE_HOME:-${HOME}/.cache}"
export XDG_STATE_HOME="${XDG_STATE_HOME:-${HOME}/.local/state}"

# LANG
export LANGUAGE=en_US.UTF-8
export LANG=en_US.UTF-8

# ls (Solarized Dark)
# di=directory(blue), ln=symlink(cyan), ex=executable(green)
export LSCOLORS=GxfxcxdxCxegedabagacad
export LS_COLORS='di=1;36:ln=1;35:so=1;32:pi=33:ex=1;32:bd=1;34;46:cd=1;34;43:su=0;41:sg=0;46:tw=0;42:ow=1;34;43'

# zsh
# グローバルの /etc/z* を読まないため、zsh 起動の最初期で設定する
setopt no_global_rcs
export HISTFILE="${XDG_STATE_HOME}/zsh/history"
export HISTSIZE=10000000
export SAVEHIST=${HISTSIZE}

# 元のターミナル環境を保存（tmux起動前）
if [[ -z "$ORIGINAL_TERM_PROGRAM" && -n "$TERM_PROGRAM" ]]; then
    export ORIGINAL_TERM_PROGRAM="$TERM_PROGRAM"
fi

# editor（常にnvimを使用）
export EDITOR='nvim'
export GIT_EDITOR='nvim'

# pager
# less の基本オプション
export LESS='-FRX'

# Perl
export PERL_RL='EditLine'

# Load local config (not tracked in git)
# Use this file for machine-specific settings. Secrets should prefer 1Password.
if [[ -f "${HOME}/.zshenv.local" ]]; then
    source "${HOME}/.zshenv.local"
fi

# ~/.zshenv.local で XDG_STATE_HOME を上書きした場合も履歴保存先を追従させる
export HISTFILE="${XDG_STATE_HOME}/zsh/history"

# 履歴保存先は起動時に確実に用意しておく
if [[ ! -d "${HISTFILE:h}" ]]; then
    mkdir -p "${HISTFILE:h}" 2>/dev/null || true
fi

# Claude Code
export DISABLE_TELEMETRY=true
export DISABLE_ERROR_REPORTING=true
export DISABLE_BUG_COMMAND=true
export CLAUDE_ENV_FILE="${XDG_CONFIG_HOME}/claude_env.sh"

export DOTFILES_1PASSWORD_VAULT="${DOTFILES_1PASSWORD_VAULT:-dotfiles}"
export DOTFILES_1PASSWORD_ITEM="${DOTFILES_1PASSWORD_ITEM:-shared-env}"
export DOTFILES_1PASSWORD_AUTOLOAD="${DOTFILES_1PASSWORD_AUTOLOAD:-0}"

########################################
# Environment
########################################

# ターミナル環境の判定と適切なTERM設定
# 基本的にTERMはターミナルエミュレータが設定するので、
# 特殊な場合を除いて上書きしない
if [[ -n "$TMUX" ]]; then
    # tmux内では設定しない（tmux.confの設定を使用）
    :
elif [[ "$TERM_PROGRAM" = "vscode" ]] || [[ -n "$VSCODE_INJECTION" ]]; then
    # VSCode/Cursorの場合のみ明示的に設定
    export TERM="xterm-256color"
fi
# iTerm2は適切なTERMを設定するので、上書きしない

########################################
# anyenv (非対話シェル用)
########################################
# anyenv の実行ファイルと shims を利用可能にする
# 対話シェルでも zshenv から読み込まれるため、先に追加しておく
export ANYENV_ROOT="${ANYENV_ROOT:-${HOME}/.anyenv}"
typeset -g anyenv_bin_dir=""
for anyenv_cmd in "${ANYENV_ROOT}/bin/anyenv" "/opt/homebrew/bin/anyenv" "/usr/local/bin/anyenv" "/home/linuxbrew/.linuxbrew/bin/anyenv"; do
    if [[ -x "$anyenv_cmd" ]]; then
        anyenv_bin_dir="${anyenv_cmd:h}"
        break
    fi
done
if [[ -n "$anyenv_bin_dir" ]]; then
    typeset -gx -U path
    path=(${anyenv_bin_dir} ${path})
fi
if [[ ! -o interactive ]] && [[ -d "${ANYENV_ROOT}/shims" ]]; then
    typeset -gx -U path
    path=(${ANYENV_ROOT}/shims ${path})
fi
if [[ ! -o interactive ]] && [[ -d "${ANYENV_ROOT}/envs" ]]; then
    # anyenv 配下の各 env に対応する *_ROOT と bin/shims を追加する
    typeset anyenv_env_root anyenv_env_name anyenv_env_var
    for anyenv_env_root in "${ANYENV_ROOT}"/envs/*(N/); do
        anyenv_env_name="${anyenv_env_root:t}"
        anyenv_env_var="${${anyenv_env_name:u}//-/_}_ROOT"
        export "${anyenv_env_var}=${anyenv_env_root}"
    done
    unset anyenv_env_root anyenv_env_name anyenv_env_var

    typeset -gx -U path
    path=(
        ${ANYENV_ROOT}/envs/*/shims(N-/)
        ${ANYENV_ROOT}/envs/*/bin(N-/)
        ${path}
    )
fi

########################################
# mise shims (非対話シェル用)
########################################
# Claude Code などの非対話 zsh でツールコマンドを利用可能にする
# 対話シェルでは 10-env.zsh の mise activate で動的に管理
if [[ -d "${HOME}/.local/share/mise/shims" ]]; then
    typeset -gx -U path
    path=(${HOME}/.local/share/mise/shims ${path})
fi

typeset -gx -U path
path=(
    ${HOME}/.local/bin
    ${GOBIN}
    ${HOME}/.cargo/bin
    ${path}
)

if [[ "$CODESPACES" = "true" ]]; then
    # Codespacesの場合
    export SHELL="/usr/bin/zsh"

    export VSCODE_IPC_HOOK_CLI=$(find /tmp -maxdepth 1 -name 'vscode-ipc-*' -printf '%T@ %p\n' 2>/dev/null | sort -rn | head -n1 | cut -d' ' -f2-)
fi

if [[ -f "/proc/version" ]] && grep -q -i "microsoft" /proc/version; then
    # WSL2 の場合
    # WSL_DISTRO_NAME が未設定の場合は /etc/os-release から取得する
    # （Ubuntu 以外の WSL ディストリビューションでも動作するよう汎用化）
    if [[ -z "${WSL_DISTRO_NAME:-}" && -f /etc/os-release ]]; then
        WSL_DISTRO_NAME="$(. /etc/os-release 2>/dev/null && printf '%s' "${NAME:-}")"
        [[ -n "$WSL_DISTRO_NAME" ]] && export WSL_DISTRO_NAME
    fi
    # ~/.vscode-server/bin へのパスが通っていると Windows 側の code が使えないため削除する
    # pathを配列として扱い、重複を防ぐ
    path=(${path:#*/.vscode-server/bin/*})
    typeset -gx -U path
fi

# less colorizer（利用可能な場合のみ有効化）
if command -v lessfilter >/dev/null 2>&1; then
    export LESSOPEN='| lessfilter %s'
fi
